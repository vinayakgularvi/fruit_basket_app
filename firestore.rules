rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEV / personal shop tool — no Firebase Auth in the app yet.
    // TODO: Replace with request.auth != null and match your users before production.
    match /customers/{customerId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /delivery_completion_events/{eventId} {
      allow read, write: if true;
    }
    match /needed_fruits/{fruitId} {
      allow read, write: if true;
    }
    // Shared custom delivery stop order (morning / evening) for all devices.
    match /delivery_route_order/{docId} {
      allow read, write: if true;
    }
    // Leads: root + nested (e.g. users/*/leads/*). collectionGroup("leads") and
    // collectionGroup().get() require every matched path to be allowed.
    match /leads/{leadId} {
      allow read, write: if true;
    }
    match /{path=**}/leads/{leadId} {
      allow read, write: if true;
    }
  }
}
